# Plotwise Environment Configuration
# Copy to .env and adjust for your environment.
# All values below are defaults — the app runs without a .env file.

# Server
PORT=8080
LOG_LEVEL=INFO

# CORS origins (comma-separated)
CORS_ORIGINS=https://limajmr-plotwise.hf.space,capacitor://localhost,https://localhost,http://localhost,http://localhost:8000,http://127.0.0.1:8000

# Database — on Railway, mount a volume at /data and set this to /data/plotwise.db
# so disease reports survive redeploys (containers are ephemeral otherwise).
# PLOTWISE_DB_PATH=/data/plotwise.db

# Seed ~70 realistic demo disease reports on first boot IF the DB is empty.
# Set to 1 on a fresh volume before a demo so the heatmap isn't blank.
# Idempotent — does nothing once any report exists.
# PLOTWISE_SEED_ON_EMPTY=1

# ML model — override if model is in a different location
# MODEL_PATH=/app/ml/saved_models/disease_model.h5

# Weather cache TTL in seconds (default 15 minutes)
WEATHER_CACHE_TTL=900
