# Plotwise Environment Configuration
# Copy to .env and adjust for your environment.
# All values below are defaults — the app runs without a .env file.

# Server
PORT=8080
LOG_LEVEL=INFO

# CORS origins (comma-separated)
CORS_ORIGINS=https://plotwise-production.up.railway.app,capacitor://localhost,http://localhost,http://localhost:8000,http://127.0.0.1:8000

# Database — on Railway, mount a volume and set this to /data/plotwise.db
# PLOTWISE_DB_PATH=/data/plotwise.db

# ML model — override if model is in a different location
# MODEL_PATH=/app/ml/saved_models/disease_model.h5

# Weather cache TTL in seconds (default 15 minutes)
WEATHER_CACHE_TTL=900
